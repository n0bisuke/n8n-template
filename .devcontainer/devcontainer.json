{
  "name": "n8n Development Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app", // ここを開発用コンテナにする
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [5678],
  "customizations": {
    "codespaces": {
      "openExternalPortsInBrowser": true
    }
  }
}
